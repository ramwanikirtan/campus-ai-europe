datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  profile  Profile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  fieldOfStudy        String
  degreeLevel         String
  gpaOriginal         String
  gpaNormalized       Float
  monthlyBudgetEur    Int
  nationality         String
  languages           Json
  countryPreferences  Json
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// University & Program Models
// ============================================

model University {
  id                          String    @id @default(cuid())
  name                        String
  country                     String
  city                        String
  websiteUrl                  String
  logoUrl                     String    @default("")
  rankingQs                   Int?
  rankingThe                  Int?
  estimatedMonthlyLivingCostEur Int     @default(0)
  description                 String    @db.Text
  foundedYear                 Int?
  wikidataId                  String?   @unique
  dataSource                  String    @default("manual")
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  programs     Program[]
  scholarships ScholarshipUniversity[]

  @@index([country])
  @@index([rankingQs])
}

model Program {
  id                     String   @id @default(cuid())
  universityId           String
  name                   String
  fieldOfStudy           String
  degreeLevel            String   // bachelors, masters, phd
  languageOfInstruction  String
  durationMonths         Int
  tuitionPerYearEur      Float    @default(0)
  minGpaRequired         Float?
  requiredLanguage       String?
  requiredLanguageLevel  String?
  applicationDeadline    String?
  applicationUrl         String?
  additionalRequirements String?  @db.Text
  dataSource             String   @default("manual")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@index([fieldOfStudy])
  @@index([degreeLevel])
}

// ============================================
// Scholarship Models
// ============================================

model Scholarship {
  id                       String   @id @default(cuid())
  name                     String
  provider                 String
  type                     String   // full_tuition, partial, stipend, travel_grant
  amountDescription        String
  amountEurMonthly         Float    @default(0)
  coverage                 String?  @db.Text
  eligibilityNationalities Json     // string[] or "all"
  eligibilityMinGpa        Float?
  eligibilityFields        Json     // string[] or "all"
  eligibilityDegreeLevels  Json     // string[]
  eligibilityOther         String?  @db.Text
  applicationDeadline      String?
  applicationUrl           String?
  dataSource               String   @default("manual")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  universities ScholarshipUniversity[]

  @@index([type])
  @@index([applicationDeadline])
}

model ScholarshipUniversity {
  id             String @id @default(cuid())
  scholarshipId  String
  universityId   String

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  university  University  @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([scholarshipId, universityId])
}

// ============================================
// AI Admissions Officer Models
// ============================================

model AdmissionsReview {
  id                 String   @id @default(cuid())
  userId             String
  universityName     String
  programName        String
  sopText            String?  @db.Text
  cvText             String?  @db.Text
  gpa                String?
  recommenders       String?
  status             String   @default("pending")
  overallScore       Int?
  verdict            String?
  verdictReason      String?  @db.Text
  strengths          Json?
  risks              Json?
  sopWeaknesses      Json?
  admissionsInsights String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  iterations ReviewIteration[]

  @@index([userId])
}

model ReviewIteration {
  id                 String   @id @default(cuid())
  reviewId           String
  iterationNumber    Int
  overallScore       Int
  verdict            String
  verdictReason      String   @db.Text
  strengths          Json
  risks              Json
  sopWeaknesses      Json
  admissionsInsights String?  @db.Text
  createdAt          DateTime @default(now())

  review AdmissionsReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}
